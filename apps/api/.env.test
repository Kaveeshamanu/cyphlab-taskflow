# Test fixture only — not a real credential. Points at an isolated database
# (taskflow_test) so vitest runs never touch the seeded dev/demo data.
# Loaded explicitly by tests/helpers/setup.ts before src/config/env.ts runs.
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow_test
NODE_ENV=test
CLIENT_URL=http://localhost:3000
COOKIE_SAMESITE=Lax
JWT_SECRET=test-fixture-jwt-secret-do-not-use-in-prod-0000
REFRESH_TOKEN_SECRET=test-fixture-refresh-secret-do-not-use-0000000
SMTP_FROM=noreply@taskflow.dev
