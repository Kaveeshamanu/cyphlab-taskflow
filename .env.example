# ─── Postgres (used by docker-compose) ───────────────────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# ─── API ─────────────────────────────────────────────────────────────────────
# Full connection string (for Neon in prod, localhost in dev)
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow

PORT=3001
NODE_ENV=development

# ─── CORS / Cookie ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000

# dev/Docker → Lax  |  prod (cross-site Vercel ↔ Render) → None
# SameSite=None also requires Secure=true and Partitioned — set automatically when None
COOKIE_SAMESITE=Lax

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=change-me-to-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Dev: leave blank — Ethereal credentials are auto-generated at startup
# Prod: fill in your SMTP provider (or Resend SMTP relay) details
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@taskflow.dev

# ─── File Storage ─────────────────────────────────────────────────────────────
# local → LocalStorageService (dev/Docker)
# cloudinary → CloudinaryStorageService (prod)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# ─── Cloudinary (prod only — STORAGE_DRIVER=cloudinary) ─────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# Must match the API origin exactly (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001
