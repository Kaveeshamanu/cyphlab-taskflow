{
  "info": {
    "name": "TaskFlow API",
    "description": "Generated from the OpenAPI spec served at /api/docs.json — run `pnpm --filter @taskflow/api generate:postman` after changing an endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register a new account",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jordan Lee\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "201 — Registered — verification email sent\n409 — Email already registered\n422 — Validation failed"
          },
          "response": []
        },
        {
          "name": "Log in and receive an access token; refresh token is set as an httpOnly cookie",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "200 — Logged in\n401 — Invalid email or password\n422 — Validation failed\n429 — Too many attempts — rate limited"
          },
          "response": []
        },
        {
          "name": "Revoke the current refresh token and clear the cookie",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "200 — Logged out"
          },
          "response": []
        },
        {
          "name": "Rotate the refresh token cookie and issue a new access token",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Reuse of an already-rotated refresh token revokes every session for that user.\n\n200 — Token refreshed\n401 — Missing"
          },
          "response": []
        },
        {
          "name": "Request a password reset email",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ]
            },
            "description": "200 — Generic success — does not confirm whether the email is registered\n422 — Validation failed\n429 — Too many attempts — rate limited"
          },
          "response": []
        },
        {
          "name": "Reset password using the token emailed by forgot-password",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<token>\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ]
            },
            "description": "200 — Password reset — all sessions revoked\n400 — Invalid or expired reset token\n422 — Validation failed"
          },
          "response": []
        },
        {
          "name": "Verify an email address using the token emailed at registration",
          "request": {
            "method": "GET",
            "auth": {
              "type": "noauth"
            },
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email/:token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email",
                ":token"
              ],
              "variable": [
                {
                  "key": "token",
                  "value": ""
                }
              ]
            },
            "description": "200 — Email verified\n400 — Invalid or expired verification token"
          },
          "response": []
        }
      ]
    }
  ]
}
